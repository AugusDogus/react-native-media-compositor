{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "mediacompositor"
  ],
  "ios": {
    "iosModuleName": "MediaCompositor"
  },
  "android": {
    "androidNamespace": [
      "mediacompositor"
    ],
    "androidCxxLibName": "MediaCompositor"
  },
  "autolinking": {
    "MediaCompositor": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridMediaCompositor"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridMediaCompositor"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules",
    "opensrc/**"
  ]
}